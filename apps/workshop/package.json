{
  "name": "delivery-monitor",
  "version": "1.0.0",
  "description": "Inventory / Delivery Monitor Dashboard (fast embedded SQLite engine)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:client": "tsc -p tsconfig.client.json",
    "typecheck": "tsc -p tsconfig.client.json --noEmit",
    "migrate": "node migrate_to_sqlite.js",
    "migrate:force": "node migrate_to_sqlite.js --force",
    "test": "npm run test:unit && npm run test:api",
    "test:unit": "node --test test/*.test.js",
    "test:api": "node test_api.js",
    "import:workshop": "node tools/import_workshop.js",
    "import:issues": "node tools/import_issues.js",
    "import:service": "node tools/import_service.js",
    "price:issues": "node tools/price_issues.js",
    "link:jobs": "node tools/link_all_to_jobs.js",
    "reattribute:daily": "node tools/reattribute_daily.js",
    "backfill:jobcost": "node tools/price_issues.js --commit && node tools/import_service.js --commit && node tools/link_all_to_jobs.js --commit --catchall && node tools/reattribute_daily.js --commit"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "express": "^4.21.0",
    "jsdom": "^29.1.1",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
