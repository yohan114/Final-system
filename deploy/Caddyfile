# E&C Super Master System — reverse proxy (Caddy v2)
#
# ONE main link, four sub-domains, ONE app process. The unified server
# (Final-system/server/unified.mjs, port 4400) hosts the portal AND all four
# systems in a single Node process and routes internally by hostname — so every
# host below proxies to the same port:
#
#   portal.ec-workshops.online            (main — the portal)
#   ├─ fuel.portal.ec-workshops.online     Fleet Fuel & Billing
#   ├─ stores.portal.ec-workshops.online   Main Stores Console
#   ├─ workshop.portal.ec-workshops.online Workshop & Stores
#   └─ oil.portal.ec-workshops.online      Oil Stock Book
#
# DNS: point one wildcard record  *.portal.ec-workshops.online  (and the apex
# portal.ec-workshops.online) at this machine — that one record covers all four
# subs. (Or add the four A records individually if you prefer no wildcard.)
#
# TLS: Caddy provisions a certificate per host automatically (Let's Encrypt).
# Each host is named explicitly below, so no wildcard certificate is required.
#
#   caddy run   --config ./Caddyfile        # foreground
#   caddy start --config ./Caddyfile        # background (or run as a service)
#
# For a LAN-only install with no public DNS, use the `tls internal` variant at
# the bottom instead (Caddy issues its own certs from a local CA).

portal.ec-workshops.online,
fuel.portal.ec-workshops.online,
stores.portal.ec-workshops.online,
workshop.portal.ec-workshops.online,
oil.portal.ec-workshops.online {
	reverse_proxy localhost:4400
}

# ── LAN-only variant (internal CA, no public DNS) ────────────────────────────
# Replace the block above with this if the portal is not internet-facing.
# Add each name to the office DNS (or hosts files) pointing at this machine.
#
# portal.ec.local,
# fuel.portal.ec.local,
# stores.portal.ec.local,
# workshop.portal.ec.local,
# oil.portal.ec.local {
# 	tls internal
# 	reverse_proxy localhost:4400
# }
