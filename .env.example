# --- E&C Master Portal environment ---
# Copy to .env and fill in. Never commit .env.

# Portal database (SQLite)
DATABASE_URL="file:./data/portal.db"

# Portal JWT signing secret — REQUIRED in production. Generate a long random
# value, e.g.  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Distinct from every system's AUTH_SECRET so co-hosting never shares a key.
PORTAL_AUTH_SECRET=""

# First-run portal admin password (else a random one is printed by the seed).
SEED_PORTAL_ADMIN_PASSWORD=""

# ── UNIFIED DEPLOYMENT (one process hosts everything — the VPS default) ─────
# The unified server (server/unified.mjs) loads THIS file first; its values win
# over every app's own .env. Health/KPI polling goes through the in-process
# channel — set the four *_BASE_URL like this and re-run the seed:
# FUEL_BASE_URL="http://127.0.0.1:4400/__sys/fuel"
# MAINSTORES_BASE_URL="http://127.0.0.1:4400/__sys/mainstores"
# WORKSHOP_BASE_URL="http://127.0.0.1:4400/__sys/workshop"
# OILBOOK_BASE_URL="http://127.0.0.1:4400/__sys/oilbook"
# Also set here (shared process): FUEL_AUTH_SECRET, MAINSTORES_AUTH_SECRET.
# DB paths are derived per app automatically; override only if a DB moved:
# PORTAL_DATABASE_URL / FUEL_DATABASE_URL / MAINSTORES_DATABASE_URL / INVENTORY_DB

# Standalone (five separate processes): where the portal polls each system.
FUEL_BASE_URL="http://localhost:3300"
MAINSTORES_BASE_URL="http://localhost:1111"
WORKSHOP_BASE_URL="http://localhost:5000"
OILBOOK_BASE_URL="http://localhost:3000"

# ── ONE main link, four subs ────────────────────────────────────────────────
# Set the portal's public host here and every system's browser-facing address is
# derived as "<sub>.<this domain>": fuel.<d>, stores.<d>, workshop.<d>, oil.<d>.
# Leave blank in local dev (systems fall back to their *_BASE_URL / localhost).
# PORTAL_PUBLIC_DOMAIN="portal.ec-workshops.online"
#   → fuel.portal.ec-workshops.online, stores.portal.ec-workshops.online,
#     workshop.portal.ec-workshops.online, oil.portal.ec-workshops.online
#
# Override any single system's address explicitly (wins over the derived sub):
# FUEL_OPEN_URL="https://fuel.portal.ec-workshops.online"
# MAINSTORES_OPEN_URL="https://stores.portal.ec-workshops.online"
# WORKSHOP_OPEN_URL="https://workshop.portal.ec-workshops.online"
# OILBOOK_OPEN_URL="https://oil.portal.ec-workshops.online"

# Per-system portal tokens for the read APIs added in M2 (x-portal-token).
FUEL_PORTAL_TOKEN=""
MAINSTORES_PORTAL_TOKEN=""
WORKSHOP_PORTAL_TOKEN=""
OILBOOK_PORTAL_TOKEN=""

# Alert-digest email (M7). Without SMTP_HOST the digest is recorded as
# "simulated" (composed + stored, not sent) — set SMTP_* to actually send.
CRON_SECRET=""                 # token for GET/POST /api/cron/alert-digest
ALERT_DIGEST_TO=""             # comma-separated recipients (else portal admins)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="E&C Master Portal <portal@ec-workshops.online>"
