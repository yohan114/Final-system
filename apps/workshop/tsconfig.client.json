{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ES2020",
        "rootDir": "src/client",
        "outDir": "js",
        "strict": false,
        "alwaysStrict": false,
        "noImplicitAny": false,
        "skipLibCheck": true,
        "removeComments": false,
        "types": []
    },
    "include": ["src/client/**/*.ts"]
}
